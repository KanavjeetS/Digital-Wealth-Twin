# ─── BACKEND ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/securewealth
JWT_SECRET=change_this_to_a_random_secret_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── AI SERVICE ─────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
# If using ngrok tunnel for AI service:
# AI_SERVICE_URL=https://abc123.ngrok.io

# ─── OPENAI (for chatbot) ────────────────────────────────────────────────────
# Paste your key below — leave blank to use mock responses
OPENAI_API_KEY=sk-your-openai-key-here

# ─── ANTHROPIC (alternative chatbot) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─── FRONTEND ────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000
REACT_APP_AI_URL=http://localhost:8000

# Production CORS (backend): single origin
# FRONTEND_URL=https://your-app.vercel.app
# Or multiple (comma-separated) for Vercel preview + production:
# FRONTEND_URLS=https://your-app.vercel.app,https://your-app-git-main-user.vercel.app
